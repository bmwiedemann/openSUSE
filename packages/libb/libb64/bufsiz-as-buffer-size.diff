+#include <cstdio>
 #include <iostream>
 
 namespace base64
@@ -22,7 +23,7 @@
 		base64_encodestate _state;
 		int _buffersize;
 
-		encoder(int buffersize_in = BUFFERSIZE)
+		encoder(int buffersize_in = BUFSIZ)
 			: _buffersize(buffersize_in)
 		{
