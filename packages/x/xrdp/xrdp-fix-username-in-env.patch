                     {
-                        g_sprintf(*passwd_file, g_cfg->auth_file_path, username);
+                        g_sprintf(*passwd_file, g_cfg->auth_file_path, pw_username);
                     }
                 }
 
@@ -222,6 +234,7 @@ env_set_user(const char *username, char
                 }
             }
 
+            g_free(pw_username);
             g_free(pw_dir);
