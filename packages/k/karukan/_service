<services>
  <service name="tar_scm" mode="manual">
    <param name="url">https://github.com/togatoga/karukan.git</param>
    <param name="scm">git</param>
    <param name="revision">v0.1.0</param>
    <param name="versionformat">@PARENT_TAG@</param>
    <param name="versionrewrite-pattern">v(.*)</param>
    <param name="versionrewrite-replacement">\1</param>
    <param name="filename">karukan</param>
    <param name="changesgenerate">enable</param>
    <param name="changesauthor">g.furuya@gaato.net</param>
  </service>
  <service name="recompress" mode="manual">
    <param name="file">*.tar</param>
    <param name="compression">zst</param>
  </service>
  <service name="set_version" mode="manual">
    <param name="basename">karukan</param>
  </service>
  <service name="cargo_vendor" mode="manual">
    <param name="src">karukan-*.tar.zst</param>
    <param name="compression">zst</param>
    <param name="update">true</param>
  </service>
  <service name="cargo_audit" mode="manual"/>
</services>
