+static rpmRC CallRpmSignFiles(Header sig, Header hdr, char *key, char *keypass)
+{
+    rpmRC rc = RPMRC_FAIL;
+    void *handle = NULL;
+    void *func;
+    char *error;
+    char *path = rpmExpand("%{?__sign_imaevm}", NULL);
+    if (!path || !*path) {
+	rpmlog(RPMLOG_ERR, _("imaevm sign plugin is not configured\n"));
+	goto exit;
+    }
+    handle = dlopen(path, RTLD_LAZY);
+    if (!handle) {
+	rpmlog(RPMLOG_ERR, _("Failed to dlopen %s %s\n"), path, dlerror());
+	goto exit;
+    }
+    func = dlsym(handle, "rpmSignFiles");
+    if ((error = dlerror()) != NULL) {
+	rpmlog(RPMLOG_ERR, _("Failed to resolve symbol %s: %s\n"),
+		"rpmSignFiles", error);
+	goto exit;
+    }
+    rc = ((rpmRC (*)(Header, Header, char *, char *))func)(sig, hdr, key, keypass);
+exit:
+    if (handle)
+	dlclose(handle);
+    _free(path);
+    return rc;
+}
