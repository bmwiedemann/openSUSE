<services>
  <service name="tar_scm" mode="manual">
    <param name="exclude">.git*</param>
    <param name="exclude">examples</param>
    <param name="filename">ocaml-sedlex</param>
    <param name="revision">589f26b0cc6c64d22953aac61a7103b4ef36cb5f</param>
    <param name="scm">git</param>
    <param name="submodules">disable</param>
    <param name="url">https://github.com/ocaml-community/sedlex.git</param>
    <param name="versionformat">@PARENT_TAG@</param>
    <param name="versionrewrite-pattern">[v]?([^+]+)(.*)</param>
    <param name="versionrewrite-replacement">\1</param>
  </service>
  <service name="recompress" mode="manual">
    <param name="file">*.tar</param>
    <param name="compression">xz</param>
  </service>
  <service name="set_version" mode="manual"/>
</services>
