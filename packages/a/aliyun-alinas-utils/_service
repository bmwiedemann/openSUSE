<?xml version="1.0"?>
<services>
  <service name="tar_scm" mode="manual">
    <param name="url">https://github.com/alibaba/alibabacloud-nas-utils.git</param>
    <param name="filename">aliyun-alinas-utils</param>
    <param name="scm">git</param>
    <param name="revision">HEAD</param>
    <param name="versionformat">2.2+%cd_%h</param>
  </service>
  <service name="recompress" mode="disabled">
    <param name="file">aliyun-alinas-utils-*.tar</param>
    <param name="compression">gz</param>
  </service>
</services>
