    curl: allow reading rpmdevtools curlrc
    
    Fixes: https://bugzilla.opensuse.org/show_bug.cgi?id=1266273

diff --git a/profiles/apparmor.d/curl b/profiles/apparmor.d/curl
index a05bd9452..9cce43cc9 100644
--- a/profiles/apparmor.d/curl
+++ b/profiles/apparmor.d/curl
@@ -43,6 +43,9 @@ profile curl /usr/bin/curl {
   # or profile refactoring
   file rw @{run}/snapd.socket,
 
+  # rpmdev-spectool runs curl with its own curlrc
+  /etc/rpmdevtools/curlrc r,
+
   # Site-specific additions and overrides. See local/README for details.
   include if exists <local/curl>
 }
