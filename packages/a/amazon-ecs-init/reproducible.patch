-export BUILDDIR="$(mktemp -d)"
+export BUILDDIR="$TOPWD/build"
 export SRCPATH="${BUILDDIR}/src/github.com/aws/amazon-ecs-agent"
 export GOPATH="${TOPWD}:${BUILDDIR}"
