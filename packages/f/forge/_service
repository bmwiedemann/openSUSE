<?xml version="1.0" ?>
<services>
	<service name="tar_scm" mode="manual">
		<param name="url">https://github.com/git-pkgs/forge</param>
		<param name="scm">git</param>
		<param name="revision">v0.5.1</param>
		<param name="filename">forge</param>
		<param name="versionformat">@PARENT_TAG@+@TAG_OFFSET@.%h</param>
		<param name="versionrewrite-pattern">v(.*)(\+0.*|(\+[^0].*))</param>
		<param name="versionrewrite-replacement">\1\3</param>
		<param name="changesgenerate">enable</param>
	</service>
	<service name="recompress" mode="manual">
		<param name="file">*.tar</param>
		<param name="compression">gz</param>
	</service>
	<service name="set_version" mode="manual"/>
	<service name="go_modules" mode="manual"/>
</services>
