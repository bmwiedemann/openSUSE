 libavdevice/libavdevice.v     |   34 +-
 libavfilter/libavfilter.v     |   94 +++++-
 libavformat/libavformat.v     |  178 +++++++++++
 libavutil/libavutil.v         |  657 +++++++++++++++++++++++++++++++++++++++++-
 libswresample/libswresample.v |   42 ++
 libswscale/libswscale.v       |   63 +++-
