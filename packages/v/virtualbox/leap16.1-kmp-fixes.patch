From: Takashi Iwai <tiwai@suse.de>
Subject: Fixes for KMP builds on openSUSE Leap 16.1

Signed-off-by: Takashi Iwai <tiwai@suse.de>

---
 include/iprt/linux/version.h             |   10 ++++++++++
 src/VBox/Additions/linux/drm/vbox_drv.c  |   11 ++++++-----
 src/VBox/Additions/linux/drm/vbox_drv.h  |   11 +++++++++++
 src/VBox/Additions/linux/drm/vbox_fb.c   |    6 +++---
 src/VBox/Additions/linux/drm/vbox_main.c |    4 ++--
 src/VBox/Additions/linux/drm/vbox_mode.c |    2 +-
 6 files changed, 33 insertions(+), 11 deletions(-)

--- a/include/iprt/linux/version.h
+++ b/include/iprt/linux/version.h
@@ -133,6 +133,16 @@
 # define RTLNX_SUSE_MAJ_PREREQ(a_iMajor, a_iMinor) (0)
 #endif
 
+#if defined(CONFIG_SUSE_PRODUCT_SLFO)
+# define RTLNX_SUSE_SLFO_RANGE(a_iMajorMin, a_iMinorMin, a_iMajorMax, a_iMinorMax) \
+        ((CONFIG_SUSE_VERSION) >= (a_iMajorMin) && \
+         (CONFIG_SUSE_PATCHLEVEL) >= (a_iMinorMin) &&\
+         (CONFIG_SUSE_VERSION) <= (a_iMajorMax) && \
+         (CONFIG_SUSE_PATCHLEVEL) <= (a_iMinorMax))
+#else
+# define RTLNX_SUSE_SLFO_RANGE(a_iMajorMin, a_iMinorMin, a_iMajorMax, a_iMinorMax) \
+        (0)
+#endif
 
 #if defined(UTS_UBUNTU_RELEASE_ABI) || defined(DOXYGEN_RUNNING)
 
--- a/src/VBox/Additions/linux/drm/vbox_drv.c
+++ b/src/VBox/Additions/linux/drm/vbox_drv.c
@@ -43,14 +43,15 @@
 # include <drm/drm_probe_helper.h>
 #endif
 
-#if RTLNX_VER_MIN(6,13,0) && defined(CONFIG_APERTURE_HELPERS) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99)
+#if RTLNX_VER_MIN(6,13,0) && defined(CONFIG_APERTURE_HELPERS) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99) || RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 # include <linux/aperture.h>
 #endif
 
 #if RTLNX_VER_RANGE(5,14,0, 6,13,0) || RTLNX_RHEL_RANGE(8,6, 8,99)
 /** RHEL 9.7 is based on 5.14, however this header is not available
  * there due to backports from newer kernels. Same for RHEL 10.X (based on 6.12) */
-# if !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99)
+/* also openSUSE Leap 16.1 dropped this file */
+# if !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99) && !RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 #  include <drm/drm_aperture.h>
 # endif
 #endif
@@ -102,7 +103,7 @@ static int vbox_pci_probe(struct pci_dev
 	}
 #endif
 
-# if RTLNX_VER_MIN(6,13,0) && defined(CONFIG_APERTURE_HELPERS) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99)
+# if RTLNX_VER_MIN(6,13,0) && defined(CONFIG_APERTURE_HELPERS) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99) || RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 	ret = aperture_remove_conflicting_pci_devices(pdev, driver.name);
 # elif RTLNX_VER_RANGE(5,14,0, 6,13,0) || RTLNX_RHEL_RANGE(8,6, 8,99)
 #  if RTLNX_VER_MIN(5,15,0) || RTLNX_RHEL_RANGE(8,7, 8,99) || RTLNX_RHEL_MIN(9,1) || RTLNX_SUSE_MAJ_PREREQ(15,4)
@@ -399,10 +400,10 @@ static struct drm_driver driver = {
 #endif
 	.name = DRIVER_NAME,
 	.desc = DRIVER_DESC,
-#if RTLNX_VER_MAX(6,14,0) && !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99)
+#if RTLNX_VER_MAX(6,14,0) && !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99) && !RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 	.date = DRIVER_DATE,
 #endif
-#if RTLNX_VER_MIN(6,15,0) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99)
+#if RTLNX_VER_MIN(6,15,0) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99) || RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 	.fbdev_probe = vboxfb_create,
 #endif
 	.major = DRIVER_MAJOR,
--- a/src/VBox/Additions/linux/drm/vbox_drv.h
+++ b/src/VBox/Additions/linux/drm/vbox_drv.h
@@ -123,6 +123,17 @@
 #else
 # define RTLNX_SUSE_MAJ_PREREQ(a_iMajor, a_iMinor) (0)
 #endif
+
+#if defined(CONFIG_SUSE_PRODUCT_SLFO)
+# define RTLNX_SUSE_SLFO_RANGE(a_iMajorMin, a_iMinorMin, a_iMajorMax, a_iMinorMax) \
+        ((CONFIG_SUSE_VERSION) >= (a_iMajorMin) && \
+         (CONFIG_SUSE_PATCHLEVEL) >= (a_iMinorMin) &&\
+         (CONFIG_SUSE_VERSION) <= (a_iMajorMax) && \
+         (CONFIG_SUSE_PATCHLEVEL) <= (a_iMinorMax))
+#else
+# define RTLNX_SUSE_SLFO_RANGE(a_iMajorMin, a_iMinorMin, a_iMajorMax, a_iMinorMax) \
+        (0)
+#endif
 /* iprt/linux/version.h copy - end */
 
 #if RTLNX_VER_MAX(4,5,0)
--- a/src/VBox/Additions/linux/drm/vbox_fb.c
+++ b/src/VBox/Additions/linux/drm/vbox_fb.c
@@ -195,7 +195,7 @@ static void drm_fb_helper_sys_imageblit(
 static struct fb_ops vboxfb_ops = {
 	.owner = THIS_MODULE,
 	.fb_check_var = drm_fb_helper_check_var,
-#if RTLNX_VER_MAX(6,15,0) && !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99)
+#if RTLNX_VER_MAX(6,15,0) && !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99) && !RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 	/* We seem do not follow all the procedure of instantiating DRM Client.
 	 * Having this callback set will trigger panic on module load. Comment
 	 * it out for now. */
@@ -420,7 +420,7 @@ int vboxfb_create(struct drm_fb_helper *
 	return 0;
 }
 
-#if RTLNX_VER_MAX(6,15,0) && !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99)
+#if RTLNX_VER_MAX(6,15,0) && !RTLNX_RHEL_RANGE(9,7, 9,99) && !RTLNX_RHEL_RANGE(10,2, 10,99) && !RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 static struct drm_fb_helper_funcs vbox_fb_helper_funcs = {
 	.fb_probe = vboxfb_create,
 };
@@ -493,7 +493,7 @@ int vbox_fbdev_init(struct drm_device *d
 	vbox->fbdev = fbdev;
 	spin_lock_init(&fbdev->dirty_lock);
 
-#if RTLNX_VER_MIN(6,15,0) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99)
+#if RTLNX_VER_MIN(6,15,0) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99) || RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 	drm_fb_helper_prepare(dev, &fbdev->helper, 32, NULL);
 #elif RTLNX_VER_MIN(6,3,0) || RTLNX_RHEL_RANGE(8,9, 8,99) || RTLNX_RHEL_RANGE(9,3, 9,99)
 	drm_fb_helper_prepare(dev, &fbdev->helper, 32, &vbox_fb_helper_funcs);
--- a/src/VBox/Additions/linux/drm/vbox_main.c
+++ b/src/VBox/Additions/linux/drm/vbox_main.c
@@ -180,7 +180,7 @@ int vbox_framebuffer_init(struct drm_dev
 {
 	int ret;
 
-#if RTLNX_VER_MIN(6,17,0) || RTLNX_RHEL_RANGE(9,8, 9,99) || RTLNX_RHEL_RANGE(10,1, 10,99)
+#if RTLNX_VER_MIN(6,17,0) || RTLNX_RHEL_RANGE(9,8, 9,99) || RTLNX_RHEL_RANGE(10,1, 10,99) || RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 	const struct drm_format_info *format = drm_get_format_info(dev, mode_cmd->pixel_format, 0);
 	drm_helper_mode_fill_fb_struct(dev, &vbox_fb->base, format, mode_cmd);
 #elif RTLNX_VER_MIN(4,11,0) || RTLNX_RHEL_MAJ_PREREQ(7,5)
@@ -201,7 +201,7 @@ int vbox_framebuffer_init(struct drm_dev
 static struct drm_framebuffer *vbox_user_framebuffer_create(
 		struct drm_device *dev,
 		struct drm_file *filp,
-#if RTLNX_VER_MIN(6,17,0) || RTLNX_RHEL_RANGE(9,8, 9,99) || RTLNX_RHEL_RANGE(10,1, 10,99)
+#if RTLNX_VER_MIN(6,17,0) || RTLNX_RHEL_RANGE(9,8, 9,99) || RTLNX_RHEL_RANGE(10,1, 10,99) || RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 		const struct drm_format_info *info,
 #endif
 #if RTLNX_VER_MIN(4,5,0) || RTLNX_RHEL_MAJ_PREREQ(7,3)
--- a/src/VBox/Additions/linux/drm/vbox_mode.c
+++ b/src/VBox/Additions/linux/drm/vbox_mode.c
@@ -660,7 +660,7 @@ static int vbox_get_modes(struct drm_con
     return num_modes;
 }
 
-#if RTLNX_VER_MIN(6,15,0) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99)
+#if RTLNX_VER_MIN(6,15,0) || RTLNX_RHEL_RANGE(9,7, 9,99) || RTLNX_RHEL_RANGE(10,2, 10,99) || RTLNX_SUSE_SLFO_RANGE(1,3, 1,3)
 static enum drm_mode_status vbox_mode_valid(struct drm_connector *connector, const struct drm_display_mode *mode)
 #elif RTLNX_VER_MIN(3,14,0) || RTLNX_RHEL_MAJ_PREREQ(7,1)
 static enum drm_mode_status vbox_mode_valid(struct drm_connector *connector, struct drm_display_mode *mode)
