<?xml version="1.0"?>
<services>
  <service name="obs_scm" mode="manual">
    <param name="scm">git</param>
    <param name="url">https://gitlab.gnome.org/GNOME/bijiben.git</param>
    <param name="revision">102d7c2f</param>
    <param name="versionformat">40.2+git@TAG_OFFSET@.%h</param>
    <!--
    <param name="versionformat">@PARENT_TAG@+git@TAG_OFFSET@.%h</param>
    <param name="versionrewrite-pattern">BIJIBEN_(\d+)_(\d+)(\+0)?(.*)?</param>
    <param name="versionrewrite-replacement">\1.\2\3\4</param>
    -->
    <param name="filename">bijiben</param>
    <param name="changesgenerate">enable</param>
  </service>
  <service name="tar" mode="manual"/>
  <service name="recompress" mode="manual">
    <param name="file">*.tar</param>
    <param name="compression">xz</param>
  </service>
  <service name="set_version" mode="manual"/>
</services>
