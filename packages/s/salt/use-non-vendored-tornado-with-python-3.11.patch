 salt/__init__.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/salt/__init__.py b/salt/__init__.py
index 16d5063fa8..1946561b53 100644
--- a/salt/__init__.py
+++ b/salt/__init__.py
@@ -12,7 +12,7 @@ if sys.version_info < (3,):
     )
     sys.stderr.flush()
 
-USE_VENDORED_TORNADO = sys.version_info < (3,12)
+USE_VENDORED_TORNADO = sys.version_info < (3,11)
 
 
 class TornadoImporter:
