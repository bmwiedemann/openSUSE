Index: sanlock-5.1.0/init.d/sanlock.service
===================================================================
--- sanlock-5.1.0.orig/init.d/sanlock.service
+++ sanlock-5.1.0/init.d/sanlock.service
@@ -6,7 +6,8 @@ Wants=wdmd.service
 
 [Service]
 Type=forking
-ExecStart=/usr/sbin/sanlock daemon
+EnvironmentFile=-/etc/sysconfig/sanlock
+ExecStart=/usr/sbin/sanlock daemon $SANLOCKOPTS
 SendSIGKILL=no
 LimitNOFILE=2048
 
Index: sanlock-5.1.0/init.d/wdmd.service
===================================================================
--- sanlock-5.1.0.orig/init.d/wdmd.service
+++ sanlock-5.1.0/init.d/wdmd.service
@@ -6,7 +6,8 @@ After=syslog.socket
 [Service]
 Type=forking
 ExecStartPre=/lib/systemd/systemd-wdmd watchdog-check
-ExecStart=/usr/sbin/wdmd
+EnvironmentFile=-/etc/sysconfig/wdmd
+ExecStart=/usr/sbin/wdmd $WDMDOPTS
 SendSIGKILL=no
 
 [Install]
