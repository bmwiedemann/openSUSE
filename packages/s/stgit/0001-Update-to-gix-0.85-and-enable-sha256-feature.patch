+/// Swapped round constants for SHA-512 family of digests
+pub(crate) const K64X2: [[u64; 2]; 40] = {
+    let mut res = [[0u64; 2]; 40];
+    let mut i = 0;
+    while i < 16 {
+        res[i] = [K64[4 * i + 1], K64[4 * i]];
+        i += 1;
+    }
+    res
+};
