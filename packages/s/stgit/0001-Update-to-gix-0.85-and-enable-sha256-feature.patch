+    let mut buf = ReadBuffer::<U4>::default();
+
+    let res = catch_unwind(AssertUnwindSafe(|| {
+        buf.write_block(
+            1,
+            |block| block.0 = [0xFF; 4],
+            |_| panic!("data read panic"),
+        );
+    }));
+
+    assert!(res.is_err());
+    let _ = buf.get_pos();
+}
