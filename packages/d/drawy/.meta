<package name="drawy" project="openSUSE:Factory">
  <title>Whiteboard application</title>
  <description>Drawy lets you create ideas, diagrams, and visual notes on an infinite whiteboard with a smooth and responsive canvas. You can draw with pressure-sensitive tablet support, add text, insert images, and use basic shapes such as rectangles, ellipses, arrows, and lines to organise your content clearly. You can choose your own color palette and export your work as image files whenever needed.</description>
  <devel project="KDE:Extra" package="drawy"/>
  <url>https://apps.kde.org/drawy</url>
</package>
