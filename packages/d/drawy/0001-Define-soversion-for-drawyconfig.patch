+            ${DRAWY_LIB_SOVERSION}
+)
+
 kconfig_add_kcfg_files(drawyconfig drawyglobalconfig.kcfgc)
 
 generate_export_header(drawyconfig BASE_NAME DRAWYCONFIG)
