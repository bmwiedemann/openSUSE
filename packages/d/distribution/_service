<services>
  <service name="tar_scm" mode="manual">
    <param name="url">https://github.com/docker/distribution.git</param>
    <param name="scm">git</param>
    <param name="exclude">.git</param>
    <param name="exclude">vendor</param>
    <param name="versionformat">3.1.1</param>
    <param name="revision">v3.1.1</param>
    <param name="changesgenerate">enable</param>
  </service>
  <service name="go_modules" mode="manual">
    <param name="compression">zst</param>
    <param name="replace">golang.org/x/crypto=golang.org/x/crypto@v0.54.0</param>
    <param name="replace">golang.org/x/net=golang.org/x/net@v0.57.0</param>
    <param name="replace">golang.org/x/text=golang.org/x/text@v0.40.0</param>
  </service>
  <service name="recompress" mode="manual">
    <param name="file">distribution-*.tar</param>
    <param name="compression">zstd</param>
  </service>
  <service name="set_version" mode="manual">
    <param name="basename">distribution</param>
  </service>
</services>
