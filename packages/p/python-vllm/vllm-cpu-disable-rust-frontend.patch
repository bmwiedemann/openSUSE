+# openSUSE: the Rust frontend (~575 crates) cannot be built in the network-less
+# OBS build root without a vendored crate tree.  It is a runtime-optional,
+# lazily-imported accelerator (Rust tool parser / rust serve frontend), so it is
+# disabled here; the Python fallbacks remain fully functional.
+if os.getenv("VLLM_DISABLE_RUST_FRONTEND", "").strip().lower() in ("1", "true"):
+    rust_extensions = []
+else:
+    rust_extensions = rust_build.rust_extensions(
+        optional=not should_require_rust_frontend()
+    )
 
