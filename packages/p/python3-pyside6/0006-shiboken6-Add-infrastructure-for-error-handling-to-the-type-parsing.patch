+            for (int a = 0; a < argCount; ++a) {
+                auto argTypeInfoO =
+                    createTypeInfoUncached(clang_getArgType(pointeeType, unsigned(a)), cacheable);
+                if (!argTypeInfoO.has_value())
+                    return std::nullopt;
+                result.addArgument(argTypeInfoO.value());
