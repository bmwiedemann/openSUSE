+
+
+class PickleTest(unittest.TestCase):
+    @unittest.skipUnless(PY36, "requires Python 3")
+    def test_persistent_id(self):
+        src = ast.literal_eval("...")
+        res = unpickle_ast(pickle_ast(src))
+        self.assertEqual(res, src)
