<package name="python-siphash24" project="openSUSE:Factory">
  <title>Streaming-capable SipHash-1-3 and SipHash-2-4 implementation</title>
  <description>A Python wrapper for the SipHash-1-3 and SipHash-2-4 pseudo-random
functions, providing a streaming-capable interface compatible with the
hashlib hash objects of the Python standard library.</description>
  <url>https://github.com/dnicolodi/python-siphash24</url>
</package>
