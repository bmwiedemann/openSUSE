 .../Issues.test_issue_no_such_assignee.yaml   | 66 +++++++++++++++++++
 1 file changed, 66 insertions(+)

diff --git a/tests/integration/forgejo/test_data/test_issues/Issues.test_issue_no_such_assignee.yaml b/tests/integration/forgejo/test_data/test_issues/Issues.test_issue_no_such_assignee.yaml
