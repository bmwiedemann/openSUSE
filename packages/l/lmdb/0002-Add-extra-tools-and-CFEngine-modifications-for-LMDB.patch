 PROGS	= $(IPROGS) mtest mtest2 mtest3 mtest4 mtest5
 all:	$(ILIBS) $(PROGS)
@@ -79,6 +80,8 @@ mtest4:	mtest4.o
 mtest5:	mtest5.o
 mtest6:	mtest6.o
 mplay:	mplay.o
