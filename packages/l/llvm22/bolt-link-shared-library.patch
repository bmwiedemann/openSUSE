+
+#include "llvm/Support/Compiler.h"
+
 namespace llvm {
 class MCInst;
 class MCInstrDesc;
@@ -23,6 +26,7 @@ bool optimizeMOVSX(MCInst &MI);
 bool optimizeINCDEC(MCInst &MI, bool In64BitMode);
 bool optimizeMOV(MCInst &MI, bool In64BitMode);
