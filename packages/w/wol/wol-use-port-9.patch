--- a/demo/nic-fake.py
+++ b/demo/nic-fake.py
@@ -5,7 +5,7 @@ from struct import *
 
 while 1:
 	s = socket (AF_INET, SOCK_DGRAM)
-	s.bind (("localhost", 40000))
+	s.bind (("localhost", 9))
 	r = s.recv (1024)
 	l = len (r)
 	data = unpack (`l` + 'B', r)
