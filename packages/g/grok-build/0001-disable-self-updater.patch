 pub async fn get_installer() -> Option<&'static str> {
+    // openSUSE: the binary is managed by the distribution package manager.
+    // Report "no installer" so every update path (automatic, leader and the
+    // explicit `grok update` command) treats the binary as up to date and
+    // never downloads or overwrites itself.
+    return None;
+    #[allow(unreachable_code)]
     if let Some(i) = env_installer() {
         return Some(i);
     }
