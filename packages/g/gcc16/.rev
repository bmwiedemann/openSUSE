    <comment>New gcc16 package.  prjconf changes required:

set

%product_libs_gcc_ver 16

add

# The following shlibs have the latest version build from GCC 15 sources
%product_libs_gcc_ver_libm220 15
%product_libs_gcc_ver_libgo24 15
%product_libs_gcc_ver_libgcobol1 15
%product_libs_gcc_ver_libgphobos6 15
%product_libs_gcc_ver_libgdruntime6 15</comment>
