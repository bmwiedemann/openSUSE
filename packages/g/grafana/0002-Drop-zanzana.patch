-func (s *Server) getStoreInfo(ctx context.Context, namespace string) (*storeInfo, error) {
-	s.storesMU.Lock()
-	defer s.storesMU.Unlock()
-	info, ok := s.stores[namespace]
-	if ok {
-		return &info, nil
-	}
-
-	store, err := s.getOrCreateStore(ctx, namespace)
-	if err != nil {
-		return nil, err
-	}
-
