-	}
-
-	for _, s := range res.GetStores() {
-		if s.GetName() == namespace {
-			return s, nil
-		}
-	}
-
-	createStoreRes, err := s.openfga.CreateStore(ctx, &openfgav1.CreateStoreRequest{Name: namespace})
-	if err != nil {
-		return nil, err
